root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,json,css,html,md,yml,yaml}]
indent_style = space
indent_size = 2

# The lazy-loaded game keeps its original 8-space indentation on purpose
# (multi-line template literals — see CLAUDE.md).
[stickfighter.js]
indent_size = 8

[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = space
indent_size = 2
